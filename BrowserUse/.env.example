# Copy this file to .env and fill your real values.
# Docker Compose automatically reads .env from the project root.

# Azure AI Foundry / Azure OpenAI (recommended)
# Use base endpoint only (no /openai path):
# Example: https://your-resource-name.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_DEPLOYMENT_NAME=your_model_deployment_name
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Optional OpenAI fallback (leave blank if using Azure)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Optional browser-use cloud key (not required for local OSS browser-use)
BROWSER_USE_API_KEY=

# Keep false for stable MCP-only runs. Set true to enable browser-use step.
RUN_BROWSER_USE=false

# Playwright MCP browser engine: chromium | msedge | chrome | firefox | webkit
MCP_BROWSER=chromium
MCP_HEADLESS=false
TEST_TIMEOUT_SECONDS=300
PAGE_SETTLE_SECONDS=5
MCP_AGENT_MAX_STEPS=60
MANUAL_LOGIN_HANDOFF=true
MANUAL_LOGIN_TIMEOUT_SECONDS=900
PLANNER_TRACE_ENABLED=true
PLANNER_TRACE_FILE=/app/reports/planner_trace.jsonl

# noVNC live view URL (after `docker compose up`):
# http://localhost:6080/vnc.html?autoconnect=1&resize=remote

# Optional test credentials for MCP pre-MFA login autofill.
# Use these instead of putting secrets directly in prompt.txt.
TEST_USERNAME=
TEST_PASSWORD=
